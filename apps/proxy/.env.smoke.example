# Smoke test configuration
# Copy this file to .env.smoke and fill in your values:
#   cp .env.smoke.example .env.smoke

# The deployed proxy URL (no trailing slash)
PROXY_URL=https://nullspend.cjones6489.workers.dev

# Must match the PLATFORM_AUTH_KEY secret on the Cloudflare Worker
PLATFORM_AUTH_KEY=

# OpenAI API key (for OpenAI smoke tests)
OPENAI_API_KEY=

# Anthropic API key (for Anthropic smoke tests)
ANTHROPIC_API_KEY=

# Direct Supabase connection string (optional — for E2E cost event verification)
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
