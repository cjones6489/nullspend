# Smoke test configuration
# Copy this file to .env.smoke and fill in your values:
#   cp .env.smoke.example .env.smoke
#
# Do NOT quote values — the vitest.smoke.config.ts parser does not strip quotes.
#   Good: NULLSPEND_API_KEY=ns_live_sk_xxx
#   Bad:  NULLSPEND_API_KEY="ns_live_sk_xxx"

# The deployed proxy URL (no trailing slash)
PROXY_URL=https://your-proxy.your-account.workers.dev

# NullSpend API key (x-nullspend-key header)
NULLSPEND_API_KEY=

# The user_id associated with the API key (for budget test setup)
NULLSPEND_SMOKE_USER_ID=

# The key_id (api_keys.id) associated with the API key (for api_key budget tests)
NULLSPEND_SMOKE_KEY_ID=

# OpenAI API key (for OpenAI smoke tests)
OPENAI_API_KEY=

# Anthropic API key (for Anthropic smoke tests)
ANTHROPIC_API_KEY=

# Direct Supabase connection string (for E2E cost event and budget verification)
DATABASE_URL=
