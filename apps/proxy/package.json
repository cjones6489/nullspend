{
  "name": "@nullspend/proxy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "generate-types": "wrangler types --env-file .dev.vars.example",
    "typecheck": "pnpm generate-types && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:do": "vitest run --config vitest.do.config.mts"
  },
  "dependencies": {
    "@nullspend/cost-engine": "workspace:*",
    "@nullspend/db": "workspace:*",
    "@upstash/qstash": "^2.9.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.34.3",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.11.0",
    "typescript": "^5.9.3",
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.71.0"
  }
}
