{
  "name": "@nullspend/cost-engine",
  "version": "0.1.0",
  "description": "Model pricing catalog and cost calculation engine for OpenAI, Anthropic, and Google AI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NullSpend/nullspend",
    "directory": "packages/cost-engine"
  },
  "homepage": "https://nullspend.com",
  "author": "NullSpend <chris@nullspend.dev>",
  "keywords": ["nullspend", "cost-calculation", "pricing", "llm", "openai", "anthropic", "finops"],
  "engines": { "node": ">=20.11.0" },
  "type": "module",
  "main": "./dist/index.cjs",
