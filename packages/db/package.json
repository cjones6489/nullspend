{
  "name": "@nullspend/db",
  "version": "0.1.0",
  "description": "Drizzle ORM schema and types for NullSpend",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
