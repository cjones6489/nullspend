{
  "name": "@nullspend/claude-agent",
  "version": "0.1.0",
  "description": "NullSpend adapter for Claude Agent SDK — route LLM calls through the NullSpend proxy",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NullSpend/nullspend",
    "directory": "packages/claude-agent"
  },
  "homepage": "https://nullspend.dev",
  "author": "NullSpend <chris@nullspend.dev>",
  "keywords": ["nullspend", "claude", "agent-sdk", "anthropic", "finops", "cost-tracking"],
  "engines": { "node": ">=20.11.0" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0 <1.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
