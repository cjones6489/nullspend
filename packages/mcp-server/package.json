{
  "name": "@nullspend/mcp-server",
  "version": "0.1.0",
  "description": "MCP server that exposes NullSpend approval tools to MCP clients",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NullSpend/nullspend",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://nullspend.dev",
  "author": "NullSpend <chris@nullspend.dev>",
  "keywords": ["nullspend", "mcp", "model-context-protocol", "approval", "human-in-the-loop"],
  "engines": { "node": ">=20.11.0" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nullspend-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@nullspend/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
