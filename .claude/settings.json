{
  "permissions": {
    "allow": [
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm proxy:test)",
      "Bash(pnpm proxy:test:*)",
      "Bash(pnpm proxy:dev)",
      "Bash(pnpm dev)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm db:*)",
      "Bash(npx vitest *)",
      "Bash(npx vitest run *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier --write *)"
    ],
    "deny": [
      "Bash(pnpm proxy:deploy)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.dev.vars)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/protect-critical-files.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/check-secrets.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-audit-before-exit-plan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs npx prettier --write 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context restored after compaction. Key reminders: pnpm test (root) and pnpm proxy:test (proxy) are separate suites. Error format: { error: \"code\", message: \"text\" }. Schema source of truth: packages/db/src/schema.ts. Run pnpm typecheck before committing.'"
          }
        ]
      }
    ]
  }
}
