# E2E test config. Copy to .env.e2e and fill in values.
# .env.e2e is gitignored. CI reads these from GitHub Actions secrets instead.
#
# See tests/e2e/README.md for the tier model and which vars each tier needs.

# ---------- Target URLs ----------

# Dashboard URL for E2E tests. Defaults to local dev server if unset.
# For Preview/Production runs, CI sets this from the deployment_status event.
# NULLSPEND_BASE_URL=http://127.0.0.1:3000

# Proxy worker URL for proxy-layer E2E tests. Defaults to production proxy.
# NULLSPEND_PROXY_URL=https://proxy.nullspend.dev

# ---------- Dashboard E2E auth ----------

# Test API key scoped to a dedicated E2E test org. NOT a production key.
# Rotate via the dashboard when suspected leaked. Docs: tests/e2e/README.md
NULLSPEND_API_KEY=

# Dev actor UUID — bypasses session auth for E2E tests via the
# `NULLSPEND_DEV_ACTOR` header path in `lib/auth/session.ts`.
NULLSPEND_DEV_ACTOR=

# Direct Postgres connection string for test-scoped cleanup SQL.
# Use the Supabase pooler URL (aws-1-*.pooler.supabase.com:6543) for
# IPv4 compatibility — see memory/project_production_urls.md.
DATABASE_URL=

# ---------- Proxy + model matrix (L4 nightly only) ----------

# Real provider keys used by the nightly full-model matrix in
# tests/e2e/proxy-nightly/. Tag every call with e2e_tier=L4 so dashboard
# analytics filter them out of customer-facing reports.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Verbose health gate (Drift-3 / G-18) ----------

# Optional. When set on the server (Vercel prod env vars), gates the
# /api/health?verbose=1 endpoint behind an `x-ops-health-secret` header.
# The E2E test reads this from the same env var to pass the header.
#
# Leave unset to disable the gate (current behavior — verbose is open).
# If set on the server but NOT here, E2E tests auto-downgrade and
# component-level assertions skip gracefully.
#
# Generate a fresh value with: openssl rand -hex 32
# INTERNAL_HEALTH_SECRET=
