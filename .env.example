# ── Database ──
# Direct Postgres connection string from your Supabase project settings.
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# ── Auth (Supabase) ──
# Supabase project credentials (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[YOUR_KEY]

# Shared secret for SDK/API key auth. Generate with: openssl rand -hex 32
NULLSPEND_API_KEY=replace_me_with_a_real_secret

# ── Redis (Upstash) ──
# Create an instance at upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Proxy (apps/proxy/ — not needed for dashboard-only dev) ──
# OpenAI API key (used by the proxy to forward requests to OpenAI)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key (used by the proxy to forward requests to Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# (Legacy — no longer used. API key auth via X-NullSpend-Key replaced this.)
# PLATFORM_AUTH_KEY=

# Deployed proxy URL (used by smoke tests)
PROXY_URL=https://proxy.nullspend.com

# Internal secret for dashboard→proxy cache invalidation (must match proxy's INTERNAL_SECRET)
PROXY_INTERNAL_URL=https://proxy.nullspend.com
PROXY_INTERNAL_SECRET=replace_me_with_a_real_secret

# ── App URL ──
# Canonical app URL for Stripe redirect URLs and other external links.
# Prevents host-header injection. On Vercel, set to your production domain.
NEXT_PUBLIC_APP_URL=https://app.nullspend.com

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
# Client-side price IDs (must match server-side values, not secrets)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ── Slack (optional) ──
# Signing secret from your Slack app's Basic Information page.
# Required only if you use the Slack approve/reject buttons.
# SLACK_SIGNING_SECRET=your_slack_signing_secret

# ── Development only (never set in production) ──
# NULLSPEND_DEV_MODE=true
# NULLSPEND_DEV_ACTOR=dev-user
