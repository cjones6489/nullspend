# Direct Postgres connection string from your Supabase project settings.
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Supabase project credentials (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[YOUR_KEY]

# Shared secret for SDK/API key auth. Generate with: openssl rand -hex 32
AGENTSEAM_API_KEY=replace_me_with_a_real_secret

# Development-only: actor ID used when Supabase auth is unavailable.
# Never set in production.
AGENTSEAM_DEV_ACTOR=dev-user

# Slack integration (optional). Signing secret from your Slack app's Basic Information page.
# Required only if you use the Slack approve/reject buttons.
# SLACK_SIGNING_SECRET=your_slack_signing_secret
