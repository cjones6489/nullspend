{
  "name": "nullspend",
  "description": "FinOps layer for AI agents — transparent proxy for cost tracking and budget enforcement",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "pnpm db:build && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "pnpm -r run test",
    "test:watch": "vitest",
    "sdk:build": "pnpm --filter @nullspend/sdk build",
    "sdk:test": "pnpm --filter @nullspend/sdk test",
    "mcp:build": "pnpm --filter @nullspend/mcp-server build",
    "mcp:test": "pnpm --filter @nullspend/mcp-server test",
    "mcp-proxy:build": "pnpm --filter @nullspend/mcp-proxy build",
    "mcp-proxy:test": "pnpm --filter @nullspend/mcp-proxy test",
    "e2e": "tsx scripts/e2e-smoke.ts",
    "e2e:auth": "tsx scripts/e2e-auth-hardening.ts",
    "e2e:observability": "tsx scripts/e2e-observability.ts",
    "e2e:resilience": "tsx scripts/e2e-resilience.ts",
    "proxy:dev": "pnpm --filter @nullspend/proxy dev",
    "proxy:deploy": "pnpm --filter @nullspend/proxy deploy",
    "proxy:test": "pnpm --filter @nullspend/proxy test",
    "proxy:smoke": "pnpm --filter @nullspend/proxy test:smoke",
    "proxy:test:integration": "pnpm --filter @nullspend/proxy test:integration",
    "cost-engine:build": "pnpm --filter @nullspend/cost-engine build",
    "cost-engine:test": "pnpm --filter @nullspend/cost-engine test",
    "db:build": "pnpm --filter @nullspend/db build",
    "db:test": "pnpm --filter @nullspend/db test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@nullspend/db": "workspace:*",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd"
    ],
    "overrides": {
      "drizzle-orm": "^0.45.1",
      "recharts": "2.15.4"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "pino-pretty": "^13.1.3",
    "shadcn": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
